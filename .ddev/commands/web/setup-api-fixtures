#!/bin/bash

## Description: Load API test fixtures (pages + content elements) into the TYPO3 MySQL DB
## Usage: setup-api-fixtures [v12|v13]
## Example: ddev setup-api-fixtures v13

set -euo pipefail

VERSION="${1:-v13}"

if [[ "$VERSION" != "v12" && "$VERSION" != "v13" ]]; then
    echo "ERROR: Unknown version '${VERSION}'. Use 'v12' or 'v13'."
    exit 1
fi

EXTENSION_DIR=/var/www/content_api
TYPO3_DIR=/var/www/html/${VERSION}
FIXTURES_DIR="${EXTENSION_DIR}/Tests/Api/Fixtures"

echo ""
echo "================================================================"
echo " setup-api-fixtures  |  ${VERSION}  |  DB: ${VERSION}"
echo "================================================================"
echo ""

# ----------------------------------------------------------------
# 1. Ensure German sys_language record exists.
#    The sys_language table was removed in TYPO3 v13 (languages are
#    now defined exclusively in the site config). Only insert for v12.
# ----------------------------------------------------------------
if mysql -h db -u root -proot "${VERSION}" -e "DESCRIBE sys_language" 2>/dev/null 1>/dev/null; then
    echo "==> Ensuring sys_language record for German (TYPO3 v12)..."
    mysql -h db -u root -proot "${VERSION}" -e "
REPLACE INTO sys_language (uid, pid, title, flag, language_isocode)
VALUES (1, 0, 'German', 'de', 'de');
"
    echo "    done."
else
    echo "==> Skipping sys_language (table not present in this TYPO3 version)."
fi

# ----------------------------------------------------------------
# 2. Import pages fixture
# ----------------------------------------------------------------
echo "==> Importing pages fixture..."
mysql -h db -u root -proot "${VERSION}" < "${FIXTURES_DIR}/pages.sql"
echo "    done."

# ----------------------------------------------------------------
# 3. Import tt_content fixture
# ----------------------------------------------------------------
echo "==> Importing tt_content fixture..."
mysql -h db -u root -proot "${VERSION}" < "${FIXTURES_DIR}/tt_content.sql"
echo "    done."

# ----------------------------------------------------------------
# 4. Flush TYPO3 cache
# ----------------------------------------------------------------
echo "==> Flushing TYPO3 cache..."
cd "${TYPO3_DIR}"
vendor/bin/typo3 cache:flush
echo "    done."

echo ""
echo "================================================================"
echo " API test fixtures loaded for ${VERSION}"
echo " Pages added under pid=1 (site root):"
echo "   /api-test-home  /api-test-media  /api-test-hidden"
echo ""
echo " Run API tests with:"
echo "   ddev test-api-${VERSION}"
echo "================================================================"
