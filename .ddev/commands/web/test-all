#!/bin/bash

## Description: Run unit + functional tests against all supported TYPO3 versions (12.4 + 13.4)
## Usage: test-all
## Example: ddev test-all
##
## Mirrors the CI matrix for the current PHP version.
## For full PHP version matrix coverage (8.2 / 8.3 / 8.4), use GitHub Actions CI.

set -euo pipefail

PASS=0
FAIL=0
RESULTS=()

SCRIPT_DIR=/var/www/content_api/.ddev/commands/web

run_suite() {
    local label="$1"
    local script="$2"

    echo ""
    echo "###############################################################"
    echo "  STARTING: ${label}"
    echo "###############################################################"

    if bash "$script"; then
        PASS=$((PASS + 1))
        RESULTS+=("  PASS  ${label}")
    else
        FAIL=$((FAIL + 1))
        RESULTS+=("  FAIL  ${label}")
    fi
}

run_suite "TYPO3 12.4" "${SCRIPT_DIR}/test-v12"
run_suite "TYPO3 13.4" "${SCRIPT_DIR}/test-v13"

echo ""
echo "###############################################################"
echo "  TEST MATRIX SUMMARY"
echo "###############################################################"
for r in "${RESULTS[@]}"; do
    echo "$r"
done
echo ""
echo "  Passed: ${PASS} / $((PASS + FAIL))"
echo "###############################################################"

if [ "$FAIL" -gt 0 ]; then
    echo ""
    echo "  ${FAIL} suite(s) FAILED. See output above."
    exit 1
fi

echo ""
echo "  All suites passed."
